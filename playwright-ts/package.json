{
  "name": "maelstromops-playwright-ts",
  "version": "1.0.0",
  "private": true,
  "description": "Gold-standard Playwright (TypeScript) E2E suite for MaelstromOps",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "codegen": "playwright codegen",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
