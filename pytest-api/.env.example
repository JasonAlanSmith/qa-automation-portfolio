# Copy to .env and adjust. Defaults target a local MaelstromOps dev instance;
# point MOPS_BASE_URL at any environment (e.g. the Azure demo instance) to run the
# exact same suite against it.
MOPS_BASE_URL=http://localhost:5009/api/v1
MOPS_TEST_EMAIL=test@test.org
MOPS_TEST_PASSWORD=test

# Optional: a second tenant's account. When set, the cross-tenant isolation test
# runs (proving tenant B can't read tenant A's data); otherwise it skips.
# MOPS_TEST_EMAIL_2=
# MOPS_TEST_PASSWORD_2=
